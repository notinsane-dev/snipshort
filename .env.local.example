# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------

# Public keys — safe to expose in the browser (prefixed NEXT_PUBLIC_).
# Used by the anon client: all queries are subject to Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️  SERVICE ROLE KEY — server-only, never expose client-side.
# Use this key (via createServiceClient in lib/supabase/server.ts) only for
# privileged server operations that must bypass RLS, such as:
#   - Atomically incrementing click counts
#   - Admin writes that users should not be able to perform directly
# Do NOT prefix with NEXT_PUBLIC_ — that would leak it to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

# ioredis connection URL — used for slug caching (SETEX/GET/DEL).
# Format:  redis://[:password@]host[:port][/db]
# For TLS (e.g. Upstash): rediss://...
REDIS_URL=

# Upstash Redis REST API — used by @upstash/ratelimit (edge-compatible HTTP client).
# If you are using Upstash, both REDIS_URL and these two vars point to the
# same database; they just use different connection methods (TCP vs HTTPS REST).
# Find these in Upstash Console → your database → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Clerk (Authentication)
# ---------------------------------------------------------------------------
# Create an app at https://dashboard.clerk.com and copy these values.

# Public key — safe in the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ⚠️  Secret key — server-only, never expose client-side.
CLERK_SECRET_KEY=

# Route configuration — where Clerk redirects for sign-in/up and after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase JWT integration:
# 1. In Clerk Dashboard → Configure → JWT Templates → New → choose "Supabase" preset
#    Name it exactly "supabase". Copy the JWKS Endpoint URL.
# 2. In Supabase Dashboard → Authentication → Sign In Methods → Third-party providers
#    → Add provider → Clerk → paste the JWKS Endpoint URL → Save.
# After this, auth.uid() inside Supabase RLS policies returns the Clerk user ID.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------

# The public base URL used to build short links and SEO canonical URLs (no trailing slash).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
